from datetime import datetime
from decimal import Decimal, InvalidOperation

from ..models.models import (
    ReconciliationCase,
    SavedCalculationScenario,
    Transaction,
    TransactionType,
    SuggestedTransaction,
    RawStatementRow,
)

ROUNDING_EPSILON = Decimal("0.0001")


def _to_decimal(value, default="0"):
    try:
        if value is None:
            return Decimal(default)
        return Decimal(str(value))
    except (InvalidOperation, TypeError, ValueError):
        return Decimal(default)


def _open_case_map(user_id):
    rows = (
        ReconciliationCase.query
        .filter_by(user_id=user_id)
        .all()
    )
    return {str(r.transaction_id): r for r in rows}


def _snap_rounding_crumb(value):
    value = _to_decimal(value)
    if abs(value) <= ROUNDING_EPSILON:
        return Decimal("0")
    return value


def _transaction_source_meta(tx):
    if not tx or not tx.source_suggestion_id:
        return {}

    suggestion = SuggestedTransaction.query.filter_by(id=tx.source_suggestion_id).first()
    if not suggestion or not suggestion.source_row_id:
        return {}

    row = RawStatementRow.query.filter_by(id=suggestion.source_row_id).first()
    if not row:
        return {}

    payload = row.raw_payload or {}
    return {
        "row_index": row.row_index,
        "raw_date": payload.get("Date"),
        "raw_definition": payload.get("Definition"),
        "raw_amount_eur": payload.get("Amount (EUR)") or payload.get("Amount"),
        "raw_gold_silver_ratio": payload.get("Gold-Silver-Ratio") or payload.get("Gold Silver Ratio"),
        "source_row_id": str(row.id),
        "suggestion_id": str(suggestion.id),
    }


def _transaction_code_prefix(tx):
    tx_type = str(tx.type.value if tx and tx.type else "").lower()
    metal = str(tx.metal.value if tx and tx.metal else "").lower()

    if tx_type == "purchase" and metal == "gold":
        return "PG"
    if tx_type == "purchase" and metal == "silver":
        return "PS"
    if tx_type == "transfer_in":
        return "TI"
    if tx_type == "transfer_out":
        return "TO"
    if tx_type == "switch":
        return "SW"
    if tx_type in {"depot_fee", "storage_fee"}:
        return "DF"
    if tx_type == "sale":
        return "SA"

    return "TX"


def _build_transaction_code_map(user_id):
    txs = (
        Transaction.query.filter_by(user_id=user_id, is_deleted=False)
        .all()
    )
    txs = sorted(txs, key=_transaction_sort_key)

    counters = {}
    code_map = {}

    for tx in txs:
        prefix = _transaction_code_prefix(tx)
        counters[prefix] = counters.get(prefix, 0) + 1
        code_map[str(tx.id)] = f"{prefix}-{counters[prefix]:04d}"

    return code_map


def _transaction_sort_key(tx):
    source_meta = _transaction_source_meta(tx)
    row_index = source_meta.get("row_index")
    try:
        row_index = int(row_index)
    except Exception:
        row_index = 0

    return (
        tx.transaction_date,
        -row_index,
        tx.created_at or datetime.min,
        str(tx.id),
    )


def _history_step_sort_key(step):
    date_value = step.get("date") or ""
    row_index = step.get("row_index")
    try:
        row_index = int(row_index)
    except Exception:
        row_index = 0

    return (
        date_value,
        -row_index,
        str(step.get("transaction_id") or ""),
        str(step.get("type") or ""),
    )


def _sorted_history(history):
    return sorted(list(history or []), key=_history_step_sort_key)


def _history_step(
    tx,
    step_type,
    quantity_grams,
    metal=None,
    from_metal=None,
    to_metal=None,
    ratio=None,
    allocated_source_quantity_grams=None,
    transaction_code=None,
):
    source_meta = _transaction_source_meta(tx)
    return {
        "transaction_id": str(tx.id) if tx else None,
        "transaction_code": transaction_code,
        "type": step_type,
        "date": tx.transaction_date.isoformat() if tx and tx.transaction_date else None,
        "ratio": float(ratio) if ratio is not None else (float(tx.ratio) if tx and tx.ratio is not None else None),
        "quantity_grams": float(quantity_grams) if quantity_grams is not None else None,
        "allocated_source_quantity_grams": (
            float(allocated_source_quantity_grams) if allocated_source_quantity_grams is not None else None
        ),
        "metal": metal,
        "from_metal": from_metal,
        "to_metal": to_metal,
        "row_index": source_meta.get("row_index"),
        "raw_definition": source_meta.get("raw_definition"),
        "source_row_id": source_meta.get("source_row_id"),
    }


def _original_purchase_date(history, tx):
    purchase_dates = [
        step.get("date")
        for step in (history or [])
        if str(step.get("type") or "").lower() == "purchase" and step.get("date")
    ]
    if purchase_dates:
        return sorted(purchase_dates)[0]

    all_dates = [step.get("date") for step in (history or []) if step.get("date")]
    if all_dates:
        return sorted(all_dates)[0]

    return tx.transaction_date.isoformat() if tx and tx.transaction_date else None


def _create_lot(
    lot_key,
    metal,
    quantity_grams,
    basis_ratio,
    tx,
    history=None,
    source_meta=None,
    display_transaction_code=None,
):
    resolved_history = _sorted_history(history or [
        _history_step(
            tx=tx,
            step_type=tx.type.value,
            quantity_grams=quantity_grams,
            metal=metal,
            ratio=tx.ratio if tx else None,
            transaction_code=display_transaction_code,
        )
    ])

    return {
        "lot_key": lot_key,
        "metal": metal,
        "quantity_grams": _to_decimal(quantity_grams),
        "basis_ratio": _to_decimal(basis_ratio) if basis_ratio is not None else None,
        "origin_transaction_id": str(tx.id),
        "display_transaction_code": display_transaction_code,
        "origin_type": tx.type.value,
        "opened_on": tx.transaction_date.isoformat(),
        "original_purchase_date": _original_purchase_date(resolved_history, tx),
        "source_meta": source_meta or {},
        "history": resolved_history,
    }


def holdings_summary(user_id):
    lots = build_current_lots(user_id)
    gold = Decimal("0")
    silver = Decimal("0")
    switch_count = 0

    txs = (
        Transaction.query.filter_by(user_id=user_id, is_deleted=False)
        .all()
    )
    txs = sorted(txs, key=_transaction_sort_key)
    case_map = _open_case_map(user_id)

    for tx in txs:
        case = case_map.get(str(tx.id))
        if tx.type == TransactionType.switch and (not case or case.status == "resolved"):
            switch_count += 1

    for lot in lots:
        qty = _to_decimal(lot.get("quantity_grams"))
        if lot.get("metal") == "gold":
            gold += qty
        elif lot.get("metal") == "silver":
            silver += qty

    fees = Decimal("0")
    for tx in txs:
        case = case_map.get(str(tx.id))
        if case and case.status != "resolved" and tx.type in {TransactionType.switch, TransactionType.sale}:
            continue
        if tx.type in {TransactionType.depot_fee, TransactionType.storage_fee}:
            fees += _to_decimal(tx.quantity_grams)

    return {
        "gold_grams": float(gold),
        "silver_grams": float(silver),
        "switch_count": switch_count,
        "storage_fee_grams": float(fees),
    }


def build_current_lots(user_id, stop_before_transaction_id=None):
    txs = (
        Transaction.query.filter_by(user_id=user_id, is_deleted=False)
        .all()
    )
    txs = sorted(txs, key=_transaction_sort_key)

    case_map = _open_case_map(user_id)
    transaction_code_map = _build_transaction_code_map(user_id)
    open_lots = []

    def prune():
        nonlocal open_lots
        for lot in open_lots:
            lot["quantity_grams"] = _snap_rounding_crumb(lot["quantity_grams"])
            lot["history"] = _sorted_history(lot.get("history") or [])
        open_lots = [lot for lot in open_lots if lot["quantity_grams"] > 0]

    def append_history(lot, step):
        step_type = str(step.get("type") or "").lower()
        if step_type == "switch_out":
            step = {**step, "type": "switch"}
        lot["history"] = _sorted_history(list(lot.get("history") or []) + [step])

    def consume_fifo(metal, amount, tx=None, history_type=None):
        remaining = _to_decimal(amount)
        consumed = []

        for lot in open_lots:
            if remaining <= 0:
                break
            if lot["metal"] != metal:
                continue
            if lot["quantity_grams"] <= 0:
                continue

            alloc = min(lot["quantity_grams"], remaining)
            if alloc > 0:
                if tx and history_type:
                    append_history(
                        lot,
                        _history_step(
                            tx=tx,
                            step_type="switch" if history_type == "switch_out" else history_type,
                            quantity_grams=alloc,
                            metal=metal,
                            from_metal=tx.from_metal.value if tx and tx.from_metal else metal,
                            to_metal=tx.to_metal.value if tx and tx.to_metal else None,
                            ratio=tx.ratio if tx else None,
                            transaction_code=transaction_code_map.get(str(tx.id)) if tx else None,
                        ),
                    )

                lot["quantity_grams"] -= alloc
                remaining -= alloc
                consumed.append((lot, alloc))

        prune()
        return consumed, remaining

    def apply_pro_rata_fee(metal, amount, tx=None, history_type="depot_fee"):
        fee_amount = _to_decimal(amount)
        if fee_amount <= 0:
            return Decimal("0")

        matching = [lot for lot in open_lots if lot["metal"] == metal and lot["quantity_grams"] > 0]
        total_open = sum((lot["quantity_grams"] for lot in matching), Decimal("0"))

        if total_open <= 0:
            return Decimal("0")

        remaining = fee_amount
        applied_total = Decimal("0")

        for idx, lot in enumerate(matching):
            if remaining <= 0:
                break

            if idx == len(matching) - 1:
                alloc = min(lot["quantity_grams"], remaining)
            else:
                raw_alloc = (fee_amount * lot["quantity_grams"] / total_open)
                alloc = min(lot["quantity_grams"], raw_alloc.quantize(Decimal("0.000001")))

            if alloc <= 0:
                continue

            if tx and history_type:
                append_history(
                    lot,
                    _history_step(
                        tx=tx,
                        step_type=history_type,
                        quantity_grams=alloc,
                        metal=metal,
                        ratio=tx.ratio if tx else None,
                        transaction_code=transaction_code_map.get(str(tx.id)) if tx else None,
                    ),
                )

            lot["quantity_grams"] -= alloc
            remaining -= alloc
            applied_total += alloc

        prune()
        return applied_total

    def consume_by_allocations(allocations, tx=None, history_type=None):
        consumed = []

        for alloc in allocations or []:
            lot_key = alloc.get("lot_key")
            qty = _to_decimal(alloc.get("allocated_quantity_grams"))
            if not lot_key or qty <= 0:
                continue

            lot = next((x for x in open_lots if x["lot_key"] == lot_key), None)
            if not lot or lot["quantity_grams"] <= 0:
                continue

            actual = min(lot["quantity_grams"], qty)
            if actual > 0:
                if tx and history_type:
                    append_history(
                        lot,
                        _history_step(
                            tx=tx,
                            step_type="switch" if history_type == "switch_out" else history_type,
                            quantity_grams=actual,
                            metal=lot["metal"],
                            from_metal=tx.from_metal.value if tx and tx.from_metal else lot["metal"],
                            to_metal=tx.to_metal.value if tx and tx.to_metal else None,
                            ratio=tx.ratio if tx else None,
                            transaction_code=transaction_code_map.get(str(tx.id)) if tx else None,
                        ),
                    )

                lot["quantity_grams"] -= actual
                consumed.append((lot, actual))

        prune()
        return consumed

    for tx in txs:
        if stop_before_transaction_id and str(tx.id) == str(stop_before_transaction_id):
            break

        case = case_map.get(str(tx.id))
        qty = _to_decimal(tx.quantity_grams)
        to_qty = _to_decimal(tx.to_quantity_grams)

        if tx.type in {TransactionType.purchase, TransactionType.transfer_in} and tx.metal:
            lot_key = f"{tx.id}:{tx.metal.value}:root"
            open_lots.append(
                _create_lot(
                    lot_key,
                    tx.metal.value,
                    qty,
                    tx.ratio,
                    tx,
                    source_meta=_transaction_source_meta(tx),
                    display_transaction_code=transaction_code_map.get(str(tx.id)),
                )
            )

        elif tx.type == TransactionType.transfer_out and tx.metal:
            if case and case.status != "resolved":
                continue

            if case and case.resolved_allocations:
                consume_by_allocations(case.resolved_allocations, tx=tx, history_type=tx.type.value)
            else:
                consume_fifo(tx.metal.value, qty, tx=tx, history_type=tx.type.value)

        elif tx.type in {TransactionType.depot_fee, TransactionType.storage_fee} and tx.metal:
            apply_pro_rata_fee(tx.metal.value, qty, tx=tx, history_type="depot_fee")

        elif tx.type == TransactionType.sale:
            if case and case.status != "resolved":
                continue

            if case and case.resolved_allocations:
                consume_by_allocations(case.resolved_allocations, tx=tx, history_type="sale")
            elif tx.metal:
                consume_fifo(tx.metal.value, qty, tx=tx, history_type="sale")

        elif tx.type == TransactionType.switch:
            if case and case.status != "resolved":
                continue

            if case and case.resolved_allocations:
                consumed = consume_by_allocations(case.resolved_allocations, tx=tx, history_type="switch_out")
            elif tx.from_metal:
                consumed, _ = consume_fifo(tx.from_metal.value, qty, tx=tx, history_type="switch_out")
            else:
                consumed = []

            total_consumed = sum((alloc for _, alloc in consumed), Decimal("0"))

            if total_consumed > 0 and to_qty > 0 and tx.to_metal:
                merged_history = []

                for source_lot, _alloc in consumed:
                    merged_history.extend(list(source_lot.get("history") or []))

                merged_history.append(
                    _history_step(
                        tx=tx,
                        step_type="switch",
                        quantity_grams=to_qty,
                        metal=tx.to_metal.value,
                        from_metal=tx.from_metal.value if tx.from_metal else None,
                        to_metal=tx.to_metal.value if tx.to_metal else None,
                        ratio=tx.ratio if tx else None,
                        allocated_source_quantity_grams=total_consumed,
                        transaction_code=transaction_code_map.get(str(tx.id)) if tx else None,
                    )
                )

                merged_history = _sorted_history(merged_history)

                lot_key = f"{tx.id}:{tx.to_metal.value}:merged"
                open_lots.append(
                    _create_lot(
                        lot_key,
                        tx.to_metal.value,
                        to_qty,
                        tx.ratio,
                        tx,
                        history=merged_history,
                        source_meta=_transaction_source_meta(tx),
                        display_transaction_code=transaction_code_map.get(str(tx.id)),
                    )
                )

        elif tx.type == TransactionType.switch_in and tx.metal:
            lot_key = f"{tx.id}:{tx.metal.value}:root"
            open_lots.append(
                _create_lot(
                    lot_key,
                    tx.metal.value,
                    qty,
                    tx.ratio,
                    tx,
                    source_meta=_transaction_source_meta(tx),
                    display_transaction_code=transaction_code_map.get(str(tx.id)),
                )
            )

    final_lots = [lot for lot in list(open_lots) if lot["quantity_grams"] > 0]

    final_lots.sort(key=lambda lot: (
        lot.get("opened_on") or "",
        lot.get("origin_type") or "",
        lot.get("lot_key") or "",
    ))

    for lot in final_lots:
        lot["quantity_grams"] = float(lot["quantity_grams"])
        if lot["basis_ratio"] is not None:
            lot["basis_ratio"] = float(lot["basis_ratio"])

    return final_lots


def calculator(user_id, target_ratio):
    return calculator_preview(user_id, target_ratio, fee_percent=3)


def calculator_preview(user_id, future_ratio, fee_percent=3):
    future_ratio = _to_decimal(future_ratio)
    fee_percent = _to_decimal(fee_percent, "3")

    if future_ratio <= 0:
        return {"error": "future_ratio_must_be_positive"}

    fee_multiplier = (Decimal("100") - fee_percent) / Decimal("100")
    if fee_multiplier <= 0:
        return {"error": "fee_percent_must_be_less_than_100"}

    lots = build_current_lots(user_id)
    previews = []
    totals = {}

    for lot in lots:
        qty = _to_decimal(lot["quantity_grams"])
        basis_ratio = _to_decimal(lot["basis_ratio"]) if lot["basis_ratio"] is not None else None
        current_metal = lot["metal"]

        if basis_ratio is None or basis_ratio <= 0:
            previews.append({
                "lot_key": lot["lot_key"],
                "current_metal": current_metal,
                "current_quantity_grams": float(qty),
                "basis_ratio": None,
                "future_ratio": float(future_ratio),
                "fee_percent": float(fee_percent),
                "can_calculate": False,
                "message": "No basis ratio stored for this lot, so gain calculation is not available.",
                "history": lot["history"],
            })
            continue

        if current_metal == "silver":
            baseline_qty = qty / fee_multiplier / basis_ratio
            projected_qty = qty / future_ratio * fee_multiplier
            compare_metal = "gold"
            target_metal = "gold"
        elif current_metal == "gold":
            baseline_qty = qty / fee_multiplier * basis_ratio
            projected_qty = qty * future_ratio * fee_multiplier
            compare_metal = "silver"
            target_metal = "silver"
        else:
            previews.append({
                "lot_key": lot["lot_key"],
                "current_metal": current_metal,
                "current_quantity_grams": float(qty),
                "basis_ratio": float(basis_ratio),
                "future_ratio": float(future_ratio),
                "fee_percent": float(fee_percent),
                "can_calculate": False,
                "message": "Unsupported current metal.",
                "history": lot["history"],
            })
            continue

        gain_pct = ((projected_qty - baseline_qty) / baseline_qty * Decimal("100")) if baseline_qty > 0 else Decimal("0")

        entry = {
            "lot_key": lot["lot_key"],
            "current_metal": current_metal,
            "target_metal": target_metal,
            "compare_metal": compare_metal,
            "current_quantity_grams": float(qty),
            "basis_ratio": float(basis_ratio),
            "future_ratio": float(future_ratio),
            "fee_percent": float(fee_percent),
            "baseline_quantity_compare_metal": float(baseline_qty),
            "projected_quantity_compare_metal": float(projected_qty),
            "gain_percent": float(round(gain_pct, 6)),
            "can_calculate": True,
            "history": lot["history"],
        }
        previews.append(entry)

        group_key = f"{current_metal}->{target_metal}"
        if group_key not in totals:
            totals[group_key] = {
                "current_metal": current_metal,
                "target_metal": target_metal,
                "compare_metal": compare_metal,
                "current_quantity_grams_total": Decimal("0"),
                "baseline_quantity_compare_metal_total": Decimal("0"),
                "projected_quantity_compare_metal_total": Decimal("0"),
            }

        totals[group_key]["current_quantity_grams_total"] += qty
        totals[group_key]["baseline_quantity_compare_metal_total"] += baseline_qty
        totals[group_key]["projected_quantity_compare_metal_total"] += projected_qty

    totals_out = []
    for _, item in totals.items():
        baseline_total = item["baseline_quantity_compare_metal_total"]
        projected_total = item["projected_quantity_compare_metal_total"]
        gain_pct = ((projected_total - baseline_total) / baseline_total * Decimal("100")) if baseline_total > 0 else Decimal("0")

        totals_out.append({
            "current_metal": item["current_metal"],
            "target_metal": item["target_metal"],
            "compare_metal": item["compare_metal"],
            "current_quantity_grams_total": float(item["current_quantity_grams_total"]),
            "baseline_quantity_compare_metal_total": float(baseline_total),
            "projected_quantity_compare_metal_total": float(projected_total),
            "gain_percent": float(round(gain_pct, 6)),
        })

    return {
        "generated_at": datetime.utcnow().isoformat() + "Z",
        "future_ratio": float(future_ratio),
        "fee_percent": float(fee_percent),
        "current_holdings_summary": holdings_summary(user_id),
        "lots": previews,
        "totals": totals_out,
        "note": "Calculator uses only current confirmed holdings. Saved scenarios are snapshots and never override actual confirmed transactions.",
    }


def save_calculator_scenario(user_id, future_ratio, fee_percent=3, scenario_name=None, notes=None):
    preview = calculator_preview(user_id, future_ratio, fee_percent)
    if "error" in preview:
        return preview

    scenario = SavedCalculationScenario(
        user_id=user_id,
        scenario_name=scenario_name,
        notes=notes,
        future_ratio=_to_decimal(future_ratio),
        fee_percent=_to_decimal(fee_percent, "3"),
        snapshot_json=preview,
    )
    from .. import db
    db.session.add(scenario)
    db.session.commit()

    return {
        "id": str(scenario.id),
        "scenario_name": scenario.scenario_name,
        "notes": scenario.notes,
        "future_ratio": float(scenario.future_ratio),
        "fee_percent": float(scenario.fee_percent),
        "created_at": scenario.created_at.isoformat() + "Z",
        "snapshot_json": scenario.snapshot_json,
    }


def list_calculator_scenarios(user_id):
    rows = (
        SavedCalculationScenario.query
        .filter_by(user_id=user_id, is_archived=False)
        .order_by(SavedCalculationScenario.created_at.desc())
        .all()
    )

    return [
        {
            "id": str(row.id),
            "scenario_name": row.scenario_name,
            "notes": row.notes,
            "future_ratio": float(row.future_ratio),
            "fee_percent": float(row.fee_percent),
            "created_at": row.created_at.isoformat() + "Z",
            "updated_at": row.updated_at.isoformat() + "Z" if row.updated_at else None,
            "snapshot_json": row.snapshot_json,
        }
        for row in rows
    ]