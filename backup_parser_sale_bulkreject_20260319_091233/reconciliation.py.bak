from datetime import datetime
from decimal import Decimal, InvalidOperation

from .. import db
from ..models.models import MetalType, RawStatementRow, SuggestedTransaction, Transaction, TransactionType


def _decimal_or_none(value):
    if value in (None, ""):
        return None
    try:
        return Decimal(str(value))
    except (InvalidOperation, TypeError, ValueError):
        return None


def _metal_or_none(value):
    if not value:
        return None
    return MetalType(str(value).lower())


def _tx_type(value):
    return TransactionType(str(value).lower())


def _row_brief(row):
    if not row:
        return {}
    payload = row.raw_payload or {}
    return {
        "row_index": row.row_index,
        "raw_date": payload.get("Date"),
        "raw_definition": payload.get("Definition"),
        "raw_amount_eur": payload.get("Amount (EUR)"),
        "raw_gold_silver_ratio": payload.get("Gold-Silver-Ratio"),
    }


def serialize_suggestion(item):
    source_row = RawStatementRow.query.filter_by(id=item.source_row_id).first()
    paired_row = RawStatementRow.query.filter_by(id=item.paired_row_id).first() if item.paired_row_id else None

    source = _row_brief(source_row)
    paired = _row_brief(paired_row)

    return {
        "id": str(item.id),
        "upload_batch_id": str(item.upload_batch_id),
        "source_row_id": str(item.source_row_id),
        "paired_row_id": str(item.paired_row_id) if item.paired_row_id else None,
        "group_key": item.group_key,
        "suggestion_type": item.suggestion_type,
        "metal": item.metal,
        "from_metal": item.from_metal,
        "to_metal": item.to_metal,
        "quantity_grams": float(item.quantity_grams) if item.quantity_grams is not None else None,
        "to_quantity_grams": float(item.to_quantity_grams) if item.to_quantity_grams is not None else None,
        "ratio": float(item.ratio) if item.ratio is not None else None,
        "notes": item.notes,
        "confidence": float(item.confidence or 0),
        "review_status": item.review_status,
        "amended_type": item.amended_type,
        "amended_metal": item.amended_metal,
        "amended_from_metal": item.amended_from_metal,
        "amended_to_metal": item.amended_to_metal,
        "amended_quantity_grams": float(item.amended_quantity_grams) if item.amended_quantity_grams is not None else None,
        "amended_to_quantity_grams": float(item.amended_to_quantity_grams) if item.amended_to_quantity_grams is not None else None,
        "amended_ratio": float(item.amended_ratio) if item.amended_ratio is not None else None,
        "amended_notes": item.amended_notes,
        "confirmed_transaction_id": str(item.confirmed_transaction_id) if item.confirmed_transaction_id else None,
        "row_index": source.get("row_index"),
        "raw_date": source.get("raw_date"),
        "raw_definition": source.get("raw_definition"),
        "raw_amount_eur": source.get("raw_amount_eur"),
        "raw_gold_silver_ratio": source.get("raw_gold_silver_ratio"),
        "paired_row_index": paired.get("row_index"),
        "paired_raw_definition": paired.get("raw_definition"),
    }


def list_review_items(user_id, status="pending"):
    query = SuggestedTransaction.query.filter_by(user_id=user_id)
    if status != "all":
        query = query.filter_by(review_status=status)
    items = query.order_by(SuggestedTransaction.created_at.desc()).all()
    return [serialize_suggestion(item) for item in items]


def build_reconciliation_cases(user_id):
    return list_review_items(user_id, status="pending")


def rebuild_positions(user_id):
    return None


def _parse_transaction_date(raw_date):
    for fmt in ("%d.%m.%Y", "%Y-%m-%d", "%d/%m/%Y"):
        try:
            return datetime.strptime(str(raw_date), fmt).date()
        except Exception:
            continue
    raise ValueError(f"Unsupported date format: {raw_date}")


def apply_review_action(user_id, suggestion_id, payload):
    payload = payload or {}
    item = SuggestedTransaction.query.filter_by(id=suggestion_id, user_id=user_id).first_or_404()
    action = payload.get("action", "confirm").lower()

    if action == "ignore":
        item.review_status = "ignored"
        item.updated_at = datetime.utcnow()
        db.session.commit()
        return serialize_suggestion(item)

    if action == "reject":
        item.review_status = "rejected"
        item.updated_at = datetime.utcnow()
        db.session.commit()
        return serialize_suggestion(item)

    final_type = payload.get("suggestion_type") or item.suggestion_type
    final_metal = payload.get("metal") if "metal" in payload else item.metal
    final_from_metal = payload.get("from_metal") if "from_metal" in payload else item.from_metal
    final_to_metal = payload.get("to_metal") if "to_metal" in payload else item.to_metal
    final_qty = _decimal_or_none(payload.get("quantity_grams")) if "quantity_grams" in payload else item.quantity_grams
    final_to_qty = _decimal_or_none(payload.get("to_quantity_grams")) if "to_quantity_grams" in payload else item.to_quantity_grams
    final_ratio = _decimal_or_none(payload.get("ratio")) if "ratio" in payload else item.ratio
    final_notes = payload.get("notes") if "notes" in payload else item.notes

    source_row = RawStatementRow.query.filter_by(id=item.source_row_id).first_or_404()
    transaction_date = _parse_transaction_date((source_row.raw_payload or {}).get("Date"))

    if final_type not in {"purchase", "transfer_in", "transfer_out", "depot_fee", "switch"}:
        raise ValueError("Only purchase, transfer_in, transfer_out, depot_fee, and switch can be confirmed")

    if final_type == "switch":
        if not final_from_metal or not final_to_metal or final_qty is None or final_to_qty is None:
            raise ValueError("Switch requires from_metal, to_metal, quantity_grams, and to_quantity_grams")
    else:
        if not final_metal or final_qty is None:
            raise ValueError("This transaction requires metal and quantity_grams")

    tx = None
    if item.confirmed_transaction_id:
        tx = Transaction.query.filter_by(id=item.confirmed_transaction_id, user_id=user_id, is_deleted=False).first()

    if tx is None:
        tx = Transaction(
            user_id=user_id,
            upload_batch_id=item.upload_batch_id,
            source_suggestion_id=item.id,
            transaction_date=transaction_date,
            type=_tx_type(final_type),
            metal=_metal_or_none(final_metal),
            from_metal=_metal_or_none(final_from_metal),
            to_metal=_metal_or_none(final_to_metal),
            quantity_grams=final_qty,
            to_quantity_grams=final_to_qty,
            ratio=final_ratio,
            notes=final_notes,
            ambiguous=False,
        )
        db.session.add(tx)
        db.session.flush()
        item.confirmed_transaction_id = tx.id
    else:
        tx.transaction_date = transaction_date
        tx.type = _tx_type(final_type)
        tx.metal = _metal_or_none(final_metal)
        tx.from_metal = _metal_or_none(final_from_metal)
        tx.to_metal = _metal_or_none(final_to_metal)
        tx.quantity_grams = final_qty
        tx.to_quantity_grams = final_to_qty
        tx.ratio = final_ratio
        tx.notes = final_notes
        tx.version += 1

    if action == "amend":
        item.review_status = "amended"
        item.amended_type = final_type
        item.amended_metal = final_metal
        item.amended_from_metal = final_from_metal
        item.amended_to_metal = final_to_metal
        item.amended_quantity_grams = final_qty
        item.amended_to_quantity_grams = final_to_qty
        item.amended_ratio = final_ratio
        item.amended_notes = final_notes
    else:
        item.review_status = "confirmed"

    item.updated_at = datetime.utcnow()
    db.session.commit()
    return serialize_suggestion(item)


def resolve_case(case_or_id, allocations=None):
    suggestion_id = str(case_or_id.id) if hasattr(case_or_id, "id") else str(case_or_id)
    payload = allocations if isinstance(allocations, dict) else {}
    return apply_review_action(payload.get("user_id"), suggestion_id, payload)
