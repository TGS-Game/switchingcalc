import csv
import hashlib
import io
import json
import re
from datetime import datetime
from decimal import Decimal, InvalidOperation

from .. import db
from ..models.models import RawStatementRow, SuggestedTransaction, UploadBatch, UploadStatus


PURCHASE_RE = re.compile(r"^(Gold|Silver)\s+purchase\s+([+-]?\d+(?:[.,]\d+)?)\s*Gramm$", re.IGNORECASE)
TRANSFER_RE = re.compile(r"^(Gold|Silver)\s+([+-]?\d+(?:[.,]\d+)?)\s*Gramm$", re.IGNORECASE)
DEPOT_FEE_RE = re.compile(r"depot\s*fee|storage\s*fee|verwahr|lager", re.IGNORECASE)
CLEAR_CASH_NOISE_RE = re.compile(r"bank transfer|wire transfer|sepa|cash deposit|cash withdrawal|zahlung|ueberweisung", re.IGNORECASE)

DEPOT_FEE_SALE_RE = re.compile(
    r"^Sale\s+([+-]?[0-9][0-9\.,]*)\s*g\s*(Gold|Silver)\s*\(Depot Fee\)$",
    re.IGNORECASE,
)

DEPOT_FEE_INFO_RE = re.compile(
    r"^Depot\s+Fee\s+as\s+of\b.*?(Gold|Silver)\s*$",
    re.IGNORECASE,
)

SWITCHPILOT_RE = re.compile(
    r"^SwitchPilot\s+(Purchase|Sale)\s*:\s*(GOLD|SILVER)\s+([+-]?[0-9][0-9\.,]*)\s*g$",
    re.IGNORECASE,
)

GENERIC_SWITCH_RE = re.compile(
    r"switch.*?(purchase|sale).*?(gold|silver).*?([+-]?[0-9][0-9\.,]*)\s*(?:g|gramm)\b",
    re.IGNORECASE,
)

MANUAL_SWITCH_OUTPUT_RE = re.compile(
    r"^SWITCH-VK\s+([0-9][0-9\.,]*)\s*g\s*(Gold|Silver)\b",
    re.IGNORECASE,
)

MANUAL_SWITCH_PLUS_RE = re.compile(
    r"^SWITCH-Plus\s+(Gold|Silver)\s*->\s*Purchase\s*:\s*([0-9][0-9\.,]*)\s*g\b",
    re.IGNORECASE,
)

BONUS_METAL_RE = re.compile(
    r"bonus\s*metal.*?(gold|silver).*?([+-]?[0-9][0-9\.,]*)\s*(?:g|gramm)\b",
    re.IGNORECASE,
)

GENERIC_PURCHASE_RE = re.compile(
    r"(gold|silver).*?purchase.*?([+-]?[0-9][0-9\.,]*)\s*(?:g|gramm)\b|purchase.*?(gold|silver).*?([+-]?[0-9][0-9\.,]*)\s*(?:g|gramm)\b",
    re.IGNORECASE,
)

GENERIC_SALE_RE = re.compile(
    r"(gold|silver).*?sale.*?([+-]?[0-9][0-9\.,]*)\s*(?:g|gramm)\b|sale.*?(gold|silver).*?([+-]?[0-9][0-9\.,]*)\s*(?:g|gramm)\b",
    re.IGNORECASE,
)


def checksum_bytes(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def _field(payload, *names):
    lowered = {str(k).strip().lower(): v for k, v in (payload or {}).items()}
    for name in names:
        if name.lower() in lowered:
            return lowered[name.lower()]
    return None


def _text(value):
    return (value or "").strip()


def _normalize_payload(payload):
    return {str(k).strip(): (str(v).strip() if v is not None else "") for k, v in (payload or {}).items()}


def _row_signature(payload):
    normalized = _normalize_payload(payload)
    blob = json.dumps(normalized, sort_keys=True, ensure_ascii=False)
    return hashlib.sha256(blob.encode("utf-8")).hexdigest()


def _already_imported_for_user(user_id, row_signature):
    existing = (
        db.session.query(RawStatementRow.id)
        .join(UploadBatch, RawStatementRow.upload_batch_id == UploadBatch.id)
        .filter(UploadBatch.user_id == user_id, RawStatementRow.row_signature == row_signature)
        .first()
    )
    return existing is not None


def _parse_decimal(value):
    if value is None:
        return None

    s = str(value).strip()
    if not s:
        return None

    s = s.replace("\u20AC", "").replace("EUR", "").replace("Gramm", "").replace("gramm", "").replace("g", "").replace(" ", "")
    s = s.replace("\u00A0", "")

    if not s:
        return None

    if "," in s and "." in s:
        if s.rfind(",") > s.rfind("."):
            s = s.replace(".", "")
            s = s.replace(",", ".")
        else:
            s = s.replace(",", "")
    elif "," in s:
        s = s.replace(".", "")
        s = s.replace(",", ".")
    elif s.count(".") > 1:
        parts = s.split(".")
        s = "".join(parts[:-1]) + "." + parts[-1]

    try:
        return Decimal(s)
    except InvalidOperation:
        return None


def _parse_date(value):
    if value is None:
        return None
    s = str(value).strip()
    for fmt in ("%d.%m.%Y", "%Y-%m-%d", "%d/%m/%Y"):
        try:
            return datetime.strptime(s, fmt).date()
        except ValueError:
            continue
    return None


def parse_csv_rows(file_bytes: bytes):
    text = file_bytes.decode("utf-8-sig")
    sample = text[:4096]

    try:
        dialect = csv.Sniffer().sniff(sample, delimiters=";,\t")
        delimiter = dialect.delimiter
    except Exception:
        delimiter = ";"

    reader = csv.DictReader(io.StringIO(text), delimiter=delimiter)
    return list(reader), text


def _ignore_reason(definition):
    d = _text(definition)
    d_lower = d.lower().strip()
    if d.startswith("ZA"):
        return "Ignored: ZA row"
    if d_lower == "cancelled switch":
        return "Ignored: Cancelled Switch"
    return None


def _looks_like_cash_noise(payload):
    definition = _text(_field(payload, "Definition"))
    amount = _field(payload, "Amount (EUR)")
    lower = definition.lower()

    if "gold" in lower or "silver" in lower or "gramm" in lower or "switch" in lower or "bonus metal" in lower or "sale" in lower:
        return False

    if amount in (None, "", "0", "0.00", "0,00"):
        return False

    if CLEAR_CASH_NOISE_RE.search(definition):
        return True

    return False


def _extract_generic_purchase(definition):
    m = GENERIC_PURCHASE_RE.search(definition)
    if not m:
        return None

    metal = m.group(1) or m.group(3)
    grams = m.group(2) or m.group(4)
    if not metal or not grams:
        return None

    return metal.lower(), _parse_decimal(grams)


def _extract_generic_sale(definition):
    m = GENERIC_SALE_RE.search(definition)
    if not m:
        return None

    metal = m.group(1) or m.group(3)
    grams = m.group(2) or m.group(4)
    if not metal or not grams:
        return None

    return metal.lower(), _parse_decimal(grams)


def _match_switch_style(definition):
    m = SWITCHPILOT_RE.match(definition)
    if m:
        return m.group(1).lower(), m.group(2).lower(), _parse_decimal(m.group(3))

    m = GENERIC_SWITCH_RE.search(definition)
    if m:
        return m.group(1).lower(), m.group(2).lower(), _parse_decimal(m.group(3))

    return None


def _match_manual_switch_output(definition):
    m = MANUAL_SWITCH_OUTPUT_RE.match(definition)
    if m:
        grams = _parse_decimal(m.group(1))
        metal = m.group(2).lower()
        return {
            "to_metal": metal,
            "to_quantity_grams": grams,
            "notes": f"Manual switch detected: output {metal.title()} only. Source metal will be assigned later.",
        }

    m = MANUAL_SWITCH_PLUS_RE.match(definition)
    if m:
        metal = m.group(1).lower()
        grams = _parse_decimal(m.group(2))
        return {
            "to_metal": metal,
            "to_quantity_grams": grams,
            "notes": f"Manual switch detected: output {metal.title()} only. Source metal will be assigned later.",
        }

    return None


def _classify_single(payload):
    definition = _text(_field(payload, "Definition"))
    ratio = _parse_decimal(_field(payload, "Gold-Silver-Ratio"))
    lower = definition.lower()

    reason = _ignore_reason(definition)
    if reason:
        return {
            "suggestion_type": "ignored",
            "metal": None,
            "from_metal": None,
            "to_metal": None,
            "quantity_grams": None,
            "to_quantity_grams": None,
            "ratio": ratio,
            "notes": reason,
            "confidence": Decimal("1.00"),
        }

    manual_switch = _match_manual_switch_output(definition)
    if manual_switch:
        return {
            "suggestion_type": "manual_switch",
            "metal": None,
            "from_metal": None,
            "to_metal": manual_switch["to_metal"],
            "quantity_grams": None,
            "to_quantity_grams": manual_switch["to_quantity_grams"],
            "ratio": ratio,
            "notes": manual_switch["notes"],
            "confidence": Decimal("0.97"),
        }

    switch_style = _match_switch_style(definition)
    if switch_style:
        direction, metal, grams = switch_style

        if _is_switchpilot_row(payload):
            if direction == "purchase":
                return {
                    "suggestion_type": "switch_pilot",
                    "metal": None,
                    "from_metal": None,
                    "to_metal": metal,
                    "quantity_grams": None,
                    "to_quantity_grams": abs(grams) if grams is not None else None,
                    "ratio": ratio,
                    "notes": "SwitchPilot row detected. Waiting for matching sale row to complete pair.",
                    "confidence": Decimal("0.92"),
                }
            return {
                "suggestion_type": "switch_pilot",
                "metal": None,
                "from_metal": metal,
                "to_metal": None,
                "quantity_grams": abs(grams) if grams is not None else None,
                "to_quantity_grams": None,
                "ratio": ratio,
                "notes": "SwitchPilot row detected. Waiting for matching purchase row to complete pair.",
                "confidence": Decimal("0.92"),
            }

        if direction == "purchase":
            return {
                "suggestion_type": "transfer_in",
                "metal": metal,
                "from_metal": None,
                "to_metal": None,
                "quantity_grams": abs(grams) if grams is not None else None,
                "to_quantity_grams": None,
                "ratio": ratio,
                "notes": f"Switch-style purchase detected for {metal.title()}",
                "confidence": Decimal("0.90"),
            }
        return {
            "suggestion_type": "transfer_out",
            "metal": metal,
            "from_metal": None,
            "to_metal": None,
            "quantity_grams": abs(grams) if grams is not None else None,
            "to_quantity_grams": None,
            "ratio": ratio,
            "notes": f"Switch-style sale detected for {metal.title()}",
            "confidence": Decimal("0.90"),
        }

    bonus_match = BONUS_METAL_RE.search(definition)
    if bonus_match:
        metal = bonus_match.group(1).lower()
        grams = _parse_decimal(bonus_match.group(2))
        return {
            "suggestion_type": "purchase",
            "metal": metal,
            "from_metal": None,
            "to_metal": None,
            "quantity_grams": grams,
            "to_quantity_grams": None,
            "ratio": ratio,
            "notes": "",
            "confidence": Decimal("0.95"),
        }

    m = PURCHASE_RE.match(definition)
    if m:
        metal = m.group(1).lower()
        grams = _parse_decimal(m.group(2))
        return {
            "suggestion_type": "purchase",
            "metal": metal,
            "from_metal": None,
            "to_metal": None,
            "quantity_grams": grams,
            "to_quantity_grams": None,
            "ratio": ratio,
            "notes": "",
            "confidence": Decimal("0.98"),
        }

    generic_purchase = _extract_generic_purchase(definition)
    if generic_purchase:
        metal, grams = generic_purchase
        return {
            "suggestion_type": "purchase",
            "metal": metal,
            "from_metal": None,
            "to_metal": None,
            "quantity_grams": grams,
            "to_quantity_grams": None,
            "ratio": ratio,
            "notes": "",
            "confidence": Decimal("0.88"),
        }

    m = TRANSFER_RE.match(definition)
    if m:
        metal = m.group(1).lower()
        grams = _parse_decimal(m.group(2))
        if grams is not None and grams < 0:
            return {
                "suggestion_type": "transfer_out",
                "metal": metal,
                "from_metal": None,
                "to_metal": None,
                "quantity_grams": abs(grams),
                "to_quantity_grams": None,
                "ratio": ratio,
                "notes": "",
                "confidence": Decimal("0.90"),
            }
        if grams is not None and grams > 0:
            return {
                "suggestion_type": "transfer_in",
                "metal": metal,
                "from_metal": None,
                "to_metal": None,
                "quantity_grams": grams,
                "to_quantity_grams": None,
                "ratio": ratio,
                "notes": "",
                "confidence": Decimal("0.90"),
            }

    depot_fee_sale = DEPOT_FEE_SALE_RE.match(definition)
    if depot_fee_sale:
        grams = _parse_decimal(depot_fee_sale.group(1))
        metal = depot_fee_sale.group(2).lower()
        return {
            "suggestion_type": "depot_fee",
            "metal": metal,
            "from_metal": None,
            "to_metal": None,
            "quantity_grams": abs(grams) if grams is not None else None,
            "to_quantity_grams": None,
            "ratio": ratio,
            "notes": "",
            "confidence": Decimal("0.99"),
        }

    generic_sale = _extract_generic_sale(definition)
    if generic_sale and "switch" not in lower:
        metal, grams = generic_sale
        return {
            "suggestion_type": "sale",
            "metal": metal,
            "from_metal": None,
            "to_metal": None,
            "quantity_grams": abs(grams) if grams is not None else None,
            "to_quantity_grams": None,
            "ratio": ratio,
            "notes": "",
            "confidence": Decimal("0.88"),
        }

    if DEPOT_FEE_RE.search(definition):
        metal = None
        if "gold" in lower:
            metal = "gold"
        elif "silver" in lower:
            metal = "silver"

        grams_match = re.search(r"([+-]?[0-9][0-9\.,]*)\s*Gramm", definition, re.IGNORECASE)
        grams = _parse_decimal(grams_match.group(1)) if grams_match else None

        return {
            "suggestion_type": "depot_fee",
            "metal": metal,
            "from_metal": None,
            "to_metal": None,
            "quantity_grams": abs(grams) if grams is not None else None,
            "to_quantity_grams": None,
            "ratio": ratio,
            "notes": "",
            "confidence": Decimal("0.75") if grams is not None else Decimal("0.55"),
        }

    if _looks_like_cash_noise(payload):
        return {
            "suggestion_type": "ignored",
            "metal": None,
            "from_metal": None,
            "to_metal": None,
            "quantity_grams": None,
            "to_quantity_grams": None,
            "ratio": ratio,
            "notes": "Ignored: likely cash/noise row",
            "confidence": Decimal("0.85"),
        }

    return {
        "suggestion_type": "unknown",
        "metal": None,
        "from_metal": None,
        "to_metal": None,
        "quantity_grams": None,
        "to_quantity_grams": None,
        "ratio": ratio,
        "notes": "Could not classify automatically",
        "confidence": Decimal("0.20"),
    }


def _transfer_parts(payload):
    definition = _text(_field(payload, "Definition"))

    switch_style = _match_switch_style(definition)
    if switch_style:
        direction, metal, grams = switch_style
        if grams is None:
            return None
        if direction == "purchase":
            return metal, abs(grams)
        return metal, -abs(grams)

    m = TRANSFER_RE.match(definition)
    if not m:
        return None

    metal = m.group(1).lower()
    grams = _parse_decimal(m.group(2))
    if grams is None:
        return None

    return metal, grams


def _amounts_match(payload_a, payload_b):
    amount_a = _parse_decimal(_field(payload_a, "Amount (EUR)"))
    amount_b = _parse_decimal(_field(payload_b, "Amount (EUR)"))
    if amount_a is None or amount_b is None:
        return False
    return abs(abs(amount_a) - abs(amount_b)) <= Decimal("0.01")


def _ratios_match(payload_a, payload_b):
    ratio_a = _parse_decimal(_field(payload_a, "Gold-Silver-Ratio"))
    ratio_b = _parse_decimal(_field(payload_b, "Gold-Silver-Ratio"))
    if ratio_a is None or ratio_b is None:
        return False
    return abs(ratio_a - ratio_b) <= Decimal("0.01")


def _looks_like_switch_row(payload):
    definition = _text(_field(payload, "Definition")).lower()
    return "switch" in definition


def _is_switchpilot_row(payload):
    definition = _text(_field(payload, "Definition"))
    return SWITCHPILOT_RE.match(definition) is not None


def _detect_switchpilot_pair(row_a, row_b):
    payload_a = row_a.raw_payload
    payload_b = row_b.raw_payload

    defn_a = _text(_field(payload_a, "Definition"))
    defn_b = _text(_field(payload_b, "Definition"))

    if not (_is_switchpilot_row(payload_a) and _is_switchpilot_row(payload_b)):
        return None

    date_a = _parse_date(_field(payload_a, "Date"))
    date_b = _parse_date(_field(payload_b, "Date"))
    amount_match = _amounts_match(payload_a, payload_b)
    ratio_match = _ratios_match(payload_a, payload_b)
    parts_a = _transfer_parts(payload_a)
    parts_b = _transfer_parts(payload_b)

    print(
        "[SWITCHPILOT DEBUG] "
        f"row_a={row_a.row_index} row_b={row_b.row_index} "
        f"date_a={date_a} date_b={date_b} "
        f"amount_a={_field(payload_a, 'Amount (EUR)')} amount_b={_field(payload_b, 'Amount (EUR)')} amount_match={amount_match} "
        f"ratio_a={_field(payload_a, 'Gold-Silver-Ratio')} ratio_b={_field(payload_b, 'Gold-Silver-Ratio')} ratio_match={ratio_match} "
        f"parts_a={parts_a} parts_b={parts_b} "
        f"defn_a={defn_a} "
        f"defn_b={defn_b}"
    )

    if date_a != date_b:
        return None

    if not amount_match:
        return None

    if not ratio_match:
        return None

    if not parts_a or not parts_b:
        return None

    metal_a, grams_a = parts_a
    metal_b, grams_b = parts_b

    if metal_a == metal_b:
        return None

    if grams_a < 0 and grams_b > 0:
        print(f"[SWITCHPILOT DEBUG] MATCH row_a={row_a.row_index} row_b={row_b.row_index} source=row_a")
        return {
            "source_row": row_a,
            "paired_row": row_b,
            "from_metal": metal_a,
            "to_metal": metal_b,
            "quantity_grams": abs(grams_a),
            "to_quantity_grams": grams_b,
            "ratio": _parse_decimal(_field(payload_a, "Gold-Silver-Ratio")) or _parse_decimal(_field(payload_b, "Gold-Silver-Ratio")),
            "notes": "",
            "suggestion_type": "switch_pilot",
            "confidence": Decimal("0.99"),
        }

    if grams_b < 0 and grams_a > 0:
        print(f"[SWITCHPILOT DEBUG] MATCH row_a={row_a.row_index} row_b={row_b.row_index} source=row_b")
        return {
            "source_row": row_b,
            "paired_row": row_a,
            "from_metal": metal_b,
            "to_metal": metal_a,
            "quantity_grams": abs(grams_b),
            "to_quantity_grams": grams_a,
            "ratio": _parse_decimal(_field(payload_a, "Gold-Silver-Ratio")) or _parse_decimal(_field(payload_b, "Gold-Silver-Ratio")),
            "notes": "",
            "suggestion_type": "switch_pilot",
            "confidence": Decimal("0.99"),
        }

    print(f"[SWITCHPILOT DEBUG] NO MATCH row_a={row_a.row_index} row_b={row_b.row_index} sign_pattern_failed")
    return None


def _detect_switch(row_a, row_b):
    payload_a = row_a.raw_payload
    payload_b = row_b.raw_payload

    date_a = _parse_date(_field(payload_a, "Date"))
    date_b = _parse_date(_field(payload_b, "Date"))
    if date_a != date_b:
        return None

    parts_a = _transfer_parts(payload_a)
    parts_b = _transfer_parts(payload_b)
    if not parts_a or not parts_b:
        return None

    metal_a, grams_a = parts_a
    metal_b, grams_b = parts_b

    if metal_a == metal_b:
        return None

    has_switch_word = _looks_like_switch_row(payload_a) or _looks_like_switch_row(payload_b)

    if has_switch_word:
        if not _ratios_match(payload_a, payload_b):
            return None
        if not _amounts_match(payload_a, payload_b):
            return None

    suggestion_type = "switch_pilot" if (_is_switchpilot_row(payload_a) and _is_switchpilot_row(payload_b)) else "switch"

    if grams_a < 0 and grams_b > 0:
        return {
            "source_row": row_a,
            "paired_row": row_b,
            "from_metal": metal_a,
            "to_metal": metal_b,
            "quantity_grams": abs(grams_a),
            "to_quantity_grams": grams_b,
            "ratio": _parse_decimal(_field(payload_a, "Gold-Silver-Ratio")) or _parse_decimal(_field(payload_b, "Gold-Silver-Ratio")),
            "notes": "",
            "suggestion_type": suggestion_type,
            "confidence": Decimal("0.99") if has_switch_word else Decimal("0.95"),
        }

    if grams_b < 0 and grams_a > 0:
        return {
            "source_row": row_b,
            "paired_row": row_a,
            "from_metal": metal_b,
            "to_metal": metal_a,
            "quantity_grams": abs(grams_b),
            "to_quantity_grams": grams_a,
            "ratio": _parse_decimal(_field(payload_a, "Gold-Silver-Ratio")) or _parse_decimal(_field(payload_b, "Gold-Silver-Ratio")),
            "notes": "",
            "suggestion_type": suggestion_type,
            "confidence": Decimal("0.99") if has_switch_word else Decimal("0.95"),
        }

    return None


def build_suggestions_for_batch(user_id, upload_batch_id):
    SuggestedTransaction.query.filter_by(upload_batch_id=upload_batch_id).delete()
    db.session.flush()

    rows = (
        RawStatementRow.query.filter_by(upload_batch_id=upload_batch_id)
        .order_by(RawStatementRow.row_index.asc())
        .all()
    )

    used_ids = set()
    suggestions = []

    for i, row_a in enumerate(rows):
        if row_a.id in used_ids:
            continue

        for j in range(i + 1, len(rows)):
            row_b = rows[j]
            if row_b.id in used_ids:
                continue

            switch = _detect_switchpilot_pair(row_a, row_b) or _detect_switch(row_a, row_b)
            if switch:
                st = SuggestedTransaction(
                    user_id=user_id,
                    upload_batch_id=upload_batch_id,
                    source_row_id=switch["source_row"].id,
                    paired_row_id=switch["paired_row"].id,
                    group_key=f"switch:{upload_batch_id}:{switch['source_row'].id}:{switch['paired_row'].id}",
                    suggestion_type=switch["suggestion_type"],
                    from_metal=switch["from_metal"],
                    to_metal=switch["to_metal"],
                    quantity_grams=switch["quantity_grams"],
                    to_quantity_grams=switch["to_quantity_grams"],
                    ratio=switch["ratio"],
                    notes=switch["notes"],
                    confidence=switch["confidence"],
                    review_status="pending",
                )
                db.session.add(st)
                suggestions.append(st)
                used_ids.add(row_a.id)
                used_ids.add(row_b.id)
                break

    for row in rows:
        if row.id in used_ids:
            continue

        suggestion = _classify_single(row.raw_payload)
        st = SuggestedTransaction(
            user_id=user_id,
            upload_batch_id=upload_batch_id,
            source_row_id=row.id,
            group_key=f"single:{upload_batch_id}:{row.id}",
            suggestion_type=suggestion["suggestion_type"],
            metal=suggestion["metal"],
            from_metal=suggestion["from_metal"],
            to_metal=suggestion["to_metal"],
            quantity_grams=suggestion["quantity_grams"],
            to_quantity_grams=suggestion["to_quantity_grams"],
            ratio=suggestion["ratio"],
            notes=suggestion["notes"],
            confidence=suggestion["confidence"],
            review_status="pending",
        )
        db.session.add(st)
        suggestions.append(st)

    db.session.commit()
    return suggestions


def create_upload(user_id, filename, source_type, file_bytes):
    if source_type != "csv":
        raise ValueError("Only CSV uploads are supported in this step")

    rows, raw_text = parse_csv_rows(file_bytes)

    batch = UploadBatch(
        user_id=user_id,
        filename=filename,
        checksum=checksum_bytes(file_bytes),
        source_type=source_type,
        status=UploadStatus.pending,
        raw_text=raw_text,
        parser_version="step2-manual-switch-v1",
    )
    db.session.add(batch)
    db.session.flush()

    new_row_count = 0
    skipped_duplicate_count = 0

    for idx, row in enumerate(rows, start=1):
        signature = _row_signature(row)
        if _already_imported_for_user(user_id, signature):
            skipped_duplicate_count += 1
            continue

        db.session.add(
            RawStatementRow(
                upload_batch_id=batch.id,
                row_index=idx,
                raw_payload=row,
                row_signature=signature,
                normalized=True,
            )
        )
        new_row_count += 1

    db.session.flush()
    suggestions = build_suggestions_for_batch(user_id, batch.id)
    batch.status = UploadStatus.needs_review
    db.session.commit()
    return batch, suggestions, new_row_count, skipped_duplicate_count


