function buildSavedAllocationState(savedAllocations = [], holdings = []) {
  const holdingsByKey = Object.fromEntries((holdings || []).map((lot) => [lot.lot_key, lot]));
  const next = {};

  (savedAllocations || []).forEach((row) => {
    const grams = Number(row?.allocated_quantity_grams);
    if (!Number.isFinite(grams) || grams <= 0) return;

    const lot = holdingsByKey[row.lot_key];
    const available = Number(lot?.quantity_grams);
    const percent = Number.isFinite(available) && available > 0 ? (grams / available) * 100 : 0;

    next[row.lot_key] = {
      grams,
      percent
    };
  });

  return next;
}

