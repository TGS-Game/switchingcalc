function formatNumber(value, digits = 4) {
  const num = Number(value);
  if (!Number.isFinite(num)) return '-';
  return new Intl.NumberFormat('en-GB', {
    minimumFractionDigits: 0,
    maximumFractionDigits: digits
  }).format(num);
}

function capitalize(value) {
  const text = String(value || '');
  if (!text) return '-';
  return text.charAt(0).toUpperCase() + text.slice(1);
}

function getDisplayCodePrefix(lot) {
  const originType = String(lot?.origin_type || '').toLowerCase();
  const metal = String(lot?.metal || '').toLowerCase();

  if (originType === 'purchase' && metal === 'gold') return 'PG';
  if (originType === 'purchase' && metal === 'silver') return 'PS';
  if (originType === 'switch' && metal === 'gold') return 'SG';
  if (originType === 'switch' && metal === 'silver') return 'GS';
  if (originType === 'transfer_in' && metal === 'gold') return 'TG';
  if (originType === 'transfer_in' && metal === 'silver') return 'TS';

  return 'MT';
}

function buildDisplayCode(lot, sequenceMap = null) {
  const lotKey = String(lot?.lot_key || '');
  const prefix = getDisplayCodePrefix(lot);

  if (sequenceMap && lotKey && sequenceMap[lotKey] != null) {
    return `${prefix}-${String(sequenceMap[lotKey]).padStart(4, '0')}`;
  }

  const existingCode = String(lot?.display_code || '');
  if (existingCode && existingCode.includes('-')) {
    const parts = existingCode.split('-');
    const existingPrefix = parts[0];
    const suffix = parts.slice(1).join('-');
    if (/^\d+$/.test(suffix)) {
      return `${existingPrefix}-${suffix.padStart(4, '0')}`;
    }
    return existingCode;
  }

  return `${prefix}-0000`;
}

function formatHistoryType(value) {
  return String(value || '')
    .replace(/_/g, ' ')
    .replace(/\b\w/g, (m) => m.toUpperCase());
}

function getDepotFeeSteps(history) {
  return Array.isArray(history)
    ? history.filter((step) => String(step?.type || '').toLowerCase() === 'depot_fee')
    : [];
}

function getNonDepotHistorySteps(history) {
  return Array.isArray(history)
    ? history.filter((step) => String(step?.type || '').toLowerCase() !== 'depot_fee')
    : [];
}

function totalDepotFees(history) {
  return getDepotFeeSteps(history).reduce((sum, step) => {
    const n = Number(step?.quantity_grams);
    return sum + (Number.isFinite(n) ? n : 0);
  }, 0);
}

function getCurrentAvailableQuantity(lot) {
  const quantity = Number(lot?.quantity_grams);
  return Number.isFinite(quantity) ? Math.max(0, quantity) : 0;
}

function getOriginalPurchaseQuantity(lot) {
  const currentAvailable = getCurrentAvailableQuantity(lot);
  return currentAvailable + totalDepotFees(lot?.history);
}

function getTransactionDisplayType(item) {
  const suggestionType = String(item?.suggestion_type || '').toLowerCase();
  const type = String(item?.transaction_type || '').toLowerCase();

  if (suggestionType === 'manual_switch') return 'Manual Switch';
  if (suggestionType === 'switch_pilot') return 'Switch Pilot';

  if (type === 'purchase') return 'Purchase';
  if (type === 'transfer_in') return 'Transfer In';
  if (type === 'transfer_out') return 'Transfer Out';
  if (type === 'sale') return 'Sale';

  return 'Switch';
}

function getTransactionDisplayMetals(item) {
  const suggestionType = String(item?.suggestion_type || '').toLowerCase();
  const sourceMetal = String(item?.source_metal || '').toLowerCase();
  const targetMetal = String(item?.target_metal || '').toLowerCase();
  const type = String(item?.transaction_type || '').toLowerCase();

  const isSwitchLike =
    suggestionType === 'manual_switch' ||
    suggestionType === 'switch_pilot' ||
    type === 'switch';

  if (!isSwitchLike) {
    return {
      source: '-',
      target: targetMetal ? capitalize(targetMetal) : '-'
    };
  }

  if (suggestionType === 'manual_switch') {
    return {
      source: 'To be assigned',
      target: targetMetal ? capitalize(targetMetal) : '-'
    };
  }

  if (sourceMetal && targetMetal && sourceMetal === targetMetal) {
    return {
      source: capitalize(sourceMetal),
      target: '-'
    };
  }

  return {
    source: sourceMetal ? capitalize(sourceMetal) : '-',
    target: targetMetal ? capitalize(targetMetal) : '-'
  };
}

function getTransactionOutputLabel(item) {
  const displayType = getTransactionDisplayType(item);
  const metals = getTransactionDisplayMetals(item);

  if (displayType === 'Switch' || displayType === 'Switch Pilot' || displayType === 'Manual Switch') {
    return metals.target !== '-' ? `Created ${metals.target} grams` : 'Created grams';
  }
  if (displayType === 'Transfer Out') return 'Transferred grams';
  if (displayType === 'Sale') return 'Sold grams';
  return 'Output grams';
}

function getTransactionInfoRows(item) {
  if (!item) return [];

  const displayType = getTransactionDisplayType(item);
  const metals = getTransactionDisplayMetals(item);

  const rows = [
    ['Type', displayType],
    ['Date', item.raw_date || item.transaction_date || '-'],
    ['Definition', item.raw_definition || '-']
  ];

  if (displayType === 'Switch' || displayType === 'Switch Pilot' || displayType === 'Manual Switch') {
    if (metals.source !== '-') rows.push(['Source metal', metals.source]);
    if (metals.target !== '-') rows.push(['Target metal', metals.target]);
  } else {
    if (metals.target !== '-') rows.push(['Metal', metals.target]);
  }

  rows.push(
    ['Required source grams', item.required_source_quantity_grams != null ? `${formatNumber(item.required_source_quantity_grams, 6)} g` : 'Set by allocation'],
    [getTransactionOutputLabel(item), item.output_quantity_grams != null ? `${formatNumber(item.output_quantity_grams, 6)} g` : '-'],
    ['Ratio', item.raw_gold_silver_ratio || (item.ratio != null ? formatNumber(item.ratio, 6) : '-')]
  );

  return rows;
}

function getTransactionMoreDetailRows(item) {
  if (!item) return [];
  return [
    ['Row', item.row_index ?? '-'],
    ['Paired row', item.paired_row_index ?? '-'],
    ['Paired row definition', item.paired_raw_definition || '-'],
    ['Amount (EUR)', item.raw_amount_eur || '-']
  ];
}

